{
  "$schema": "https://www.krakend.io/schema/v3.json",
  "version": 3,
  "port": 18080,
  "endpoints": [
    {
      "endpoint": "/tiered",
      "extra_config": {
        "qos/ratelimit/tiered": {
          "strategy": "literal",
          "key": "X-Tier",
          "tiers": {
            "gold": {"max_rate": 100, "capacity": 100},
            "silver": {"max_rate": 10, "capacity": 10}
          },
          "default": {"max_rate": 5, "capacity": 5}
        }
      },
      "backend": [
        {
          "host": ["http://127.0.0.1:8081"],
          "url_pattern": "/data"
        }
      ]
    }
  ]
}
