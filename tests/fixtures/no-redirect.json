{
  "$schema": "https://www.krakend.io/schema/v3.json",
  "version": 3,
  "port": 18080,
  "endpoints": [
    {
      "endpoint": "/noredirect",
      "output_encoding": "no-op",
      "backend": [
        {
          "host": [
            "http://127.0.0.1:8081"
          ],
          "encoding": "no-op",
          "url_pattern": "/redirect",
          "extra_config": {
            "backend/no-redirect": true
          }
        }
      ]
    }
  ]
}
